    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.28.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.11.17",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
