{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/proposals/[id]/route.ts": { "maxDuration": 60 },
    "src/app/api/proposals/[id]/signature/route.ts": { "maxDuration": 120 },
    "src/app/api/share/[token]/sign/route.ts": { "maxDuration": 120 },
    "src/app/api/share/[token]/sign/finalize/route.ts": { "maxDuration": 60 },
    "src/app/api/share/[token]/documents/[documentId]/route.ts": { "maxDuration": 30 },
    "src/app/api/share/[token]/pay/route.ts": { "maxDuration": 60 },
    "src/app/api/chat/**/route.ts": { "maxDuration": 120 },
    "src/app/api/search/**/route.ts": { "maxDuration": 60 },
    "src/app/api/files/**/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/**/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/payment-reconcile-sweep", "schedule": "0 8 * * *" },
    { "path": "/api/cron/payment-schedule-due", "schedule": "0 6 * * *" },
    { "path": "/api/cron/overdue-invoice-sweep", "schedule": "0 7 * * *" },
    { "path": "/api/cron/task-reminders", "schedule": "0 9 * * *" }
  ]
}
