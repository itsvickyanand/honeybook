{
  "name": "honeybook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "tsx watch src/worker/index.ts",
    "build": "next build",
    "start": "next start",
    "start:worker": "tsx src/worker/index.ts",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push && npm run db:post-push",
    "db:post-push": "tsx scripts/run-sql.ts prisma/post-push.sql",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && npm run db:post-push && npm run db:seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
