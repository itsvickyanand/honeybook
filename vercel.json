{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/proposals/[id]/route.ts": { "maxDuration": 60 },
    "src/app/api/proposals/[id]/signature/route.ts": { "maxDuration": 120, "memory": 1769 },
    "src/app/api/share/[token]/sign/route.ts": { "maxDuration": 120, "memory": 1769 },
    "src/app/api/share/[token]/pay/route.ts": { "maxDuration": 60 },
    "src/app/api/chat/**/route.ts": { "maxDuration": 120 },
    "src/app/api/search/**/route.ts": { "maxDuration": 60 },
    "src/app/api/files/**/route.ts": { "maxDuration": 60, "memory": 1024 }
  }
}
